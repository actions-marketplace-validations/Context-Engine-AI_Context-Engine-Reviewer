{
  "name": "context-engine-reviewer",
  "version": "1.0.0",
  "description": "Context Engine PR reviewer with standalone AI review, local dry runs, and provider adapters.",
  "main": "dist/main.js",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "npm run build && DEBUG=true node -r dotenv/config dist/main.js",
    "build": "esbuild src/main.ts src/cli.ts --bundle --platform=node --target=node24 --outdir=dist --minify --packages=bundle",
    "start": "node dist/main.js",
    "review": "node dist/cli.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [],
  "author": "Context Engine",
  "license": "AGPL-3.0-only",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "esbuild": "^0.28.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "@ai-sdk/amazon-bedrock": "^4.0.98",
    "@ai-sdk/anthropic": "^3.0.73",
    "@ai-sdk/google": "^3.0.66",
    "@ai-sdk/openai": "^3.0.55",
    "@octokit/action": "^8.0.4",
    "@octokit/plugin-retry": "^8.1.0",
    "@octokit/plugin-throttling": "^11.0.3",
    "@octokit/types": "^16.0.0",
    "ai": "^6.0.172",
    "dotenv": "^17.4.2",
    "zod": "^4.4.1"
  }
}
